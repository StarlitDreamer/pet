@Override
@Transactional(rollbackFor = Exception.class)
public void acceptOrder(Long orderId, Long shopId) {
    Order order = this.getById(orderId);
    if (order == null || !order.getShopId().equals(shopId)) {
        throw new BusinessException("订单不存在");
    }
    if (order.getStatus() != OrderStatus.PENDING_CONFIRM.getCode()) {
        throw new BusinessException("订单状态异常，无法接单");
    }
    order.setStatus(OrderStatus.CONFIRMED.getCode());
    order.setUpdateTime(LocalDateTime.now());
    this.updateById(order);

    // 发送消息通知宠物主人
    messageService.sendSystemMessage(order.getUserId(),
        "您的订单[" + order.getOrderNo() + "]已被服务商确认接单");
}

@Override
@Transactional(rollbackFor = Exception.class)
public void checkIn(Long orderId, Long shopId) {
    Order order = this.getById(orderId);
    if (order.getStatus() != OrderStatus.CONFIRMED.getCode()) {
        throw new BusinessException("订单状态异常，无法办理入托");
    }
    order.setStatus(OrderStatus.IN_PROGRESS.getCode());
    order.setCheckInTime(LocalDateTime.now());
    order.setUpdateTime(LocalDateTime.now());
    this.updateById(order);

    messageService.sendSystemMessage(order.getUserId(),
        "您的宠物已成功入托，订单号：" + order.getOrderNo());
}
